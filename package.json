{
  "name": "@printwithsynergy/synergy-mcp",
  "version": "0.1.0",
  "description": "Cross-stack dev-audit MCP server for the Print With Synergy stack — blast-radius queries, floor-pin grid, pattern audit, and stack health grid across codex-pdf / lint-pdf / lens-pdf / compile-pdf / synergy / platform.",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/printwithsynergy/synergy-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "synergy-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0"
}
